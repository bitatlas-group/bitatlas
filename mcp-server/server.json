{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "BitAtlas",
  "description": "Zero Knowledge Cloud Drive for Humans and Agents. Secure, persistent, encrypted storage for AI agents. EU-hosted.",
  "repository": {
    "url": "https://github.com/bitatlas-group/bitatlas",
    "source": "github",
    "subfolder": "mcp-server"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@bitatlas/mcp-server",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "BITATLAS_API_KEY",
          "description": "Your BitAtlas API key (starts with ba_). Get one at https://bitatlas.io/dashboard",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "BITATLAS_API_URL",
          "description": "BitAtlas API base URL",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "icons": [
    {
      "src": "https://bitatlas.io/icon.png"
    }
  ]
}
